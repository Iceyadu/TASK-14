# Database (DB_USERNAME preferred; DB_USER is accepted as fallback in application.yml)
DB_ROOT_PASSWORD=examroot
DB_NAME=exam_scheduling
DB_USER=examuser
DB_USERNAME=examuser
DB_PASSWORD=exampass
DB_HOST=mysql
DB_PORT=3306

# Security (maps to app.signing-secret and app.encryption.aes-key)
APP_SIGNING_SECRET=change-this-signing-secret-in-production-min-32-chars
# AES key must be Base64-encoded 16, 24, or 32 raw bytes (example below is 32 bytes)
APP_ENCRYPTION_KEY=Q2hhbmdlVGhpc1RvQVJlYWxQcm9kdWN0aW9uS2V5ISE=

# BCrypt
BCRYPT_STRENGTH=12

# Session
SESSION_TIMEOUT_MINUTES=30
REMEMBER_DEVICE_DAYS=7

# Lockout
LOCKOUT_MAX_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15

# Rate Limiting
RATE_LIMIT_USER_PER_MINUTE=60
RATE_LIMIT_IP_PER_MINUTE=300

# WeChat (optional intranet integration)
WECHAT_ENABLED=false
WECHAT_MODE=disabled
WECHAT_HTTP_ENDPOINT=http://wechat-gateway.internal:8081

# Import
MAX_IMPORT_FILE_SIZE_MB=10
IMPORT_BATCH_SIZE=500

# Jobs
JOB_POLL_INTERVAL_SECONDS=5
NOTIFICATION_MAX_RETRIES=3
IDEMPOTENCY_KEY_TTL_HOURS=24
